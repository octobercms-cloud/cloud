{
    "name": "octobercloud/runtime",
    "type": "library",
    "require": {
        "illuminate/console": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "OctoberCloud\\Runtime\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OctoberCloud\\Runtime\\CloudServiceProvider"
            ]
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    }
}
